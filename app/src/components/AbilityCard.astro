---
import type { Ability } from '../lib/abilities';
import { VAR_ORDER, VAR_LABELS, resolveValue } from '../lib/abilities';

interface Props {
  ability: Ability;
  mode?: 'build' | 'play';
}
const { ability, mode = 'build' } = Astro.props;
const ADV_COLS = [0, 1, 2];

const sub = [ability.role, ability.mode].filter(Boolean).join(' · ');

// Play mode: only the rows a character actually has a value for.
const playRows = VAR_ORDER
  .map((k) => ({ key: k, label: VAR_LABELS[k], value: resolveValue(ability.vars[k], ability.current?.[k]) }))
  .filter((r) => r.value && r.value !== '—');

// Option blocks split by placement: 'top' renders above the table, the rest below.
const opts = ability.options ?? [];
const topOpts = opts.filter((o) => o.placement === 'top');
const bottomOpts = opts.filter((o) => o.placement !== 'top');
---

<section class={`acard acard--${mode}`}>
  <header class="acard__banner">
    <span class="acard__name">{ability.name}</span>
    <span class="acard__cat">{ability.category}</span>
  </header>
  {sub && <p class="acard__sub">{sub}</p>}

  {ability.builder && (
    <p class="acard__builder">
      <strong>Spell Builder</strong> — this Ability can be taken multiple times, allowing you to build many
      different spells with the building blocks below. You can rename this and any other new spell you create.
    </p>
  )}

  {topOpts.length > 0 && (
    <dl class="acard__opts acard__opts--top">
      {topOpts.map((o) => (
        <div class="acard__opt">
          <dt class="acard__opt-label">{o.label}</dt>
          <dd class="acard__opt-detail">
            {o.note && <p class="acard__opt-note">{o.note}</p>}
            {o.ladders ? (
              <table class="acard__table acard__table--build acard__subtable">
                <thead>
                  <tr>
                    <th class="acard__var"></th>
                    <th>Base</th>
                    <th>&#9312;</th>
                    <th>&#9313;</th>
                    <th>&#9314;</th>
                  </tr>
                </thead>
                <tbody>
                  {o.ladders.map((l) => (
                    <tr>
                      <th scope="row" class="acard__var">{l.name}</th>
                      <td>{l.base ?? '—'}{!o.hideCosts && o.baseCost && (
                        <Fragment>{' '}<span class={`pip pip--${o.baseCost}`}>{o.baseCost}</span></Fragment>
                      )}</td>
                      {ADV_COLS.map((i) => (
                        l.advances?.[i]
                          ? (
                            <td>
                              {l.advances[i].value}
                              {!o.hideCosts && (
                                <Fragment>{' '}<span class={`pip pip--${l.advances[i].cost}`}>{l.advances[i].cost}{l.advances[i].note ? `·${l.advances[i].note}` : ''}</span></Fragment>
                              )}
                            </td>
                          )
                          : <td class="acard__empty">—</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : Array.isArray(o.detail) ? (
              <ul>{o.detail.map((d) => <li>{d}</li>)}</ul>
            ) : (
              o.detail
            )}
          </dd>
        </div>
      ))}
    </dl>
  )}

  {mode === 'build' ? (
    <table class="acard__table acard__table--build">
      <thead>
        <tr>
          <th class="acard__var">Variable</th>
          <th>Base</th>
          <th>&#9312;</th>
          <th>&#9313;</th>
          <th>&#9314;</th>
        </tr>
      </thead>
      <tbody>
        {VAR_ORDER.map((k) => {
          const v = ability.vars[k];
          const base = v?.base ?? '—';
          const adv = v?.advances ?? [];
          const blank = base === '—' && adv.length === 0;
          return (
            <tr class={blank ? 'acard__row--locked' : undefined}>
              <th scope="row" class="acard__var">{VAR_LABELS[k]}</th>
              <td>{base}</td>
              {ADV_COLS.map((i) => (
                adv[i]
                  ? (
                    <td>
                      {adv[i].value}{' '}
                      <span class={`pip pip--${adv[i].cost}`}>{adv[i].cost}{adv[i].note ? `·${adv[i].note}` : ''}</span>
                    </td>
                  )
                  : <td class="acard__empty">—</td>
              ))}
            </tr>
          );
        })}
      </tbody>
    </table>
  ) : (
    <table class="acard__table acard__table--play">
      <tbody>
        {playRows.map((r) => (
          <tr>
            <th scope="row" class="acard__var">{r.label}</th>
            <td>{r.value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  {bottomOpts.length > 0 && (
    <dl class="acard__opts">
      {bottomOpts.map((o) => (
        <div class="acard__opt">
          <dt class="acard__opt-label">{o.label}</dt>
          <dd class="acard__opt-detail">
            {o.note && <p class="acard__opt-note">{o.note}</p>}
            {o.ladders ? (
              <table class="acard__table acard__table--build acard__subtable">
                <thead>
                  <tr>
                    <th class="acard__var"></th>
                    <th>Base</th>
                    <th>&#9312;</th>
                    <th>&#9313;</th>
                    <th>&#9314;</th>
                  </tr>
                </thead>
                <tbody>
                  {o.ladders.map((l) => (
                    <tr>
                      <th scope="row" class="acard__var">{l.name}</th>
                      <td>{l.base ?? '—'}{!o.hideCosts && o.baseCost && (
                        <Fragment>{' '}<span class={`pip pip--${o.baseCost}`}>{o.baseCost}</span></Fragment>
                      )}</td>
                      {ADV_COLS.map((i) => (
                        l.advances?.[i]
                          ? (
                            <td>
                              {l.advances[i].value}
                              {!o.hideCosts && (
                                <Fragment>{' '}<span class={`pip pip--${l.advances[i].cost}`}>{l.advances[i].cost}{l.advances[i].note ? `·${l.advances[i].note}` : ''}</span></Fragment>
                              )}
                            </td>
                          )
                          : <td class="acard__empty">—</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : Array.isArray(o.detail) ? (
              <ul>{o.detail.map((d) => <li>{d}</li>)}</ul>
            ) : (
              o.detail
            )}
          </dd>
        </div>
      ))}
    </dl>
  )}

  {ability.feats && (
    <p class="acard__feats"><strong>Feats:</strong> {ability.feats}</p>
  )}
</section>

<style>
  .acard {
    border: 1px solid rgba(120, 90, 40, 0.40);
    border-radius: 7px;
    background: rgba(120, 90, 40, 0.035);
    margin: 1.6rem 0;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(60, 45, 20, 0.10);
  }
  .acard__banner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0.9rem;
    background: rgba(120, 90, 40, 0.16);
    border-bottom: 1px solid rgba(120, 90, 40, 0.30);
  }
  .acard__name {
    font-family: var(--font-display, Georgia, 'Times New Roman', serif);
    font-weight: 700;
    font-size: 1.18rem;
    letter-spacing: 0.01em;
    color: #4a3719;
  }
  .acard__cat {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 0.72rem;
    color: #6a532a;
    white-space: nowrap;
  }
  .acard__sub {
    margin: 0;
    padding: 0.3rem 0.9rem 0;
    font-size: 0.78rem;
    font-style: italic;
    color: #6a532a;
  }

  .acard__table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.6rem 0 0;
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .acard__table th,
  .acard__table td {
    text-align: left;
    vertical-align: top;
    padding: 0.42rem 0.7rem;
    border-top: 1px solid rgba(120, 90, 40, 0.18);
  }
  .acard__table thead th {
    border-top: none;
    border-bottom: 1px solid rgba(120, 90, 40, 0.30);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6a532a;
    font-weight: 700;
  }
  .acard__var {
    font-weight: 700;
    color: #4a3719;
    white-space: nowrap;
    width: 1%;
  }
  /* Build mode: roomy advancement columns so a sentence or two wraps cleanly. */
  .acard__table--build td { min-width: 7.5rem; }
  .acard__table--build thead th:nth-child(n+3) { text-align: left; color: #8a6d35; }
  .acard__empty { color: rgba(120, 90, 40, 0.35); }
  .acard__row--locked th,
  .acard__row--locked td { color: rgba(74, 55, 25, 0.45); }
  .acard__table--build tbody tr:nth-child(even) { background: rgba(120, 90, 40, 0.04); }

  /* The .pip styles (Minor = light outline, Major = filled) are defined once,
     site-wide, in global.scss so the same boxes appear everywhere a cost is given. */

  .acard__feats {
    margin: 0;
    padding: 0.55rem 0.9rem 0.75rem;
    border-top: 1px solid rgba(120, 90, 40, 0.18);
    font-size: 0.83rem;
    color: #5a4a2c;
  }

  /* Spell-builder callout: the "name it / buy it again" message, set apart. */
  .acard__builder {
    margin: 0;
    padding: 0.6rem 0.9rem;
    border-top: 1px solid rgba(120, 90, 40, 0.18);
    background: rgba(120, 90, 40, 0.07);
    font-size: 0.84rem;
    color: #5a4a2c;
  }
  .acard__builder strong { color: #4a3719; }

  /* Option groups: each labelled block stands apart from the next. */
  .acard__opts {
    margin: 0;
    padding: 0 0.9rem 0.4rem;
  }
  .acard__opt {
    padding: 0.5rem 0;
    border-top: 1px solid rgba(120, 90, 40, 0.16);
  }
  .acard__opt-label {
    margin: 0 0 0.2rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6a532a;
  }
  .acard__opt-detail {
    margin: 0;
    font-size: 0.84rem;
    color: #5a4a2c;
  }
  .acard__opt-note {
    margin: 0 0 0.4rem;
    font-size: 0.82rem;
    font-style: italic;
    color: #6a532a;
  }
  /* A hook's advancement ladder, rendered as a compact build-table. */
  .acard__subtable {
    margin: 0.15rem 0 0.3rem;
    border: 1px solid rgba(120, 90, 40, 0.22);
    border-radius: 5px;
  }
  .acard__subtable td { min-width: 6rem; }
  .acard__opt-detail ul {
    margin: 0;
    padding-left: 1.15rem;
    list-style: none;
  }
  .acard__opt-detail li {
    margin: 0.18rem 0;
    position: relative;
  }
  .acard__opt-detail li::before {
    content: '◆';
    position: absolute;
    left: -1.15rem;
    color: var(--gold, #b8924a);
    font-size: 0.7em;
    top: 0.15em;
  }
</style>
