---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';
import { getCollection, render } from 'astro:content';
import { WORKS, getWork } from '../../lib/texts';

// This route serves two kinds of page at /library/<slug>/:
//   • a single one-page text (the `library` collection), and
//   • the contents/landing page of a multi-part work (the `texts` registry).
// The per-part reader pages live one level deeper, at /library/<work>/<part>/.
export async function getStaticPaths() {
  const docs = await getCollection('library');
  const docPaths = docs.map((doc) => ({
    params: { slug: doc.id },
    props: { type: 'doc' as const, doc },
  }));
  const workPaths = WORKS.map((work) => ({
    params: { slug: work.slug },
    props: { type: 'work' as const, workSlug: work.slug },
  }));
  return [...docPaths, ...workPaths];
}

const props = Astro.props;
const partSlug = (id: string) => id.split('/').slice(1).join('/');

let title: string;
let description: string | undefined;
let docData: any = null;
let DocContent: any = null;
let work: any = null;
let parts: any[] = [];
let first: any = null;

if (props.type === 'doc') {
  docData = props.doc.data;
  DocContent = (await render(props.doc)).Content;
  title = docData.title;
  description = docData.summary;
} else {
  work = getWork(props.workSlug);
  parts = (await getCollection('texts'))
    .filter((e) => e.id.split('/')[0] === props.workSlug)
    .sort((a, b) => a.data.order - b.data.order);
  first = parts[0];
  title = work.title;
  description = work.summary;
}
---

<Base title={title} description={description}>
  <p class="back-link"><a href={url('library/')}>← The Library</a></p>

  {props.type === 'doc' ? (
    <>
      <header class="saint-head">
        {docData.kind && <p class="eyebrow">{docData.kind}</p>}
        <h1>{docData.title}</h1>
        {(docData.author || docData.date) && (
          <p class="byline">{docData.author}{docData.author && docData.date ? ' · ' : ''}{docData.date}</p>
        )}
        {(docData.artist || docData.medium) && (
          <p class="byline byline--art">{docData.artist}{docData.artist && docData.medium ? ' · ' : ''}{docData.medium}</p>
        )}
      </header>
      <article class="prose">
        {docData.plate && (
          <figure class="plate plate--inset">
            <img src={url(docData.plate)} alt={docData.plateAlt ?? ''} />
            {docData.plateCaption && <figcaption>{docData.plateCaption}</figcaption>}
          </figure>
        )}
        {DocContent && <DocContent />}
      </article>
    </>
  ) : (
    <>
      <header class="saint-head">
        {work.kind && <p class="eyebrow">{work.kind}</p>}
        <h1>{work.title}</h1>
        {(work.author || work.date) && (
          <p class="byline">{work.author}{work.author && work.date ? ' · ' : ''}{work.date}</p>
        )}
        {(work.artist || work.medium) && (
          <p class="byline byline--art">{work.artist}{work.artist && work.medium ? ' · ' : ''}{work.medium}</p>
        )}
      </header>

      {work.lede && <p class="lede">{work.lede}</p>}

      {work.plate && (
        <figure class="plate">
          <img src={url(work.plate)} alt={work.plateAlt ?? ''} />
          {work.plateCaption && <figcaption>{work.plateCaption}</figcaption>}
        </figure>
      )}

      {first && (
        <p style="margin:1.6rem 0;">
          <a class="tag tag--fundator" href={url(`library/${work.slug}/${partSlug(first.id)}/`)}>Begin reading →</a>
        </p>
      )}

      <h2>Contents</h2>
      <ol class="entry-list">
        {parts.map((p) => (
          <li><a href={url(`library/${work.slug}/${partSlug(p.id)}/`)}>{p.data.title}</a></li>
        ))}
      </ol>
    </>
  )}
</Base>
