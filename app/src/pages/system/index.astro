---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';

// Wireframe table of contents for the rules system. Each entry carries a status
// so the page doubles as a build tracker; `href` is set once a section exists.
type Status = 'live' | 'designed' | 'progress' | 'planned';
interface Entry { title: string; blurb: string; status: Status; href?: string; }
interface Part { part: string; items: Entry[]; }

const parts: Part[] = [
  { part: 'I · Foundations', items: [
    { title: 'Introduction & How to Play', blurb: 'What the game is, and the d20 core it runs on.', status: 'planned' },
    { title: 'Character Creation', blurb: 'Advances (Major & Minor), levels 0–11, and milestone advancement.', status: 'designed' },
    { title: 'Attributes, Offenses & Defenses', blurb: 'The six attributes, AC, and the Armoured / Unarmoured defenses.', status: 'designed' },
    { title: 'Skills', blurb: 'The twenty-nine skills, each tied to an attribute.', status: 'designed' },
  ]},
  { part: 'II · Classes & Abilities', items: [
    { title: 'Classes & Paths', blurb: 'Eleven vocations, each with three Paths. The Soldier is written up in full.', status: 'live', href: url('system/classes/') },
    { title: 'Abilities', blurb: 'Ability Categories, and the chassis of eight dials each power is built from.', status: 'designed' },
    { title: 'Conditions', blurb: 'The laddered conditions — Daze, Control, Movement, Debuff, and the rest.', status: 'designed' },
    { title: 'Feats', blurb: 'The specialist economy — conditional perks that reshape your abilities.', status: 'designed' },
  ]},
  { part: 'III · Gear & Combat', items: [
    { title: 'Proficiencies', blurb: 'Weapon groups and armour, and how training in them works.', status: 'designed' },
    { title: 'Equipment', blurb: 'The weapon, armour, and gear lists.', status: 'progress' },
    { title: 'Combat', blurb: 'The turn, the action economy, attack resolution, range and cover.', status: 'designed' },
  ]},
  { part: 'IV · Magic', items: [
    { title: 'Magic', blurb: 'The arcane and occult arts of Avilund.', status: 'planned' },
  ]},
  { part: 'V · The Game Master’s Section', items: [
    { title: 'For the Game Master', blurb: 'Encounters, adversaries, and the secrets of running Avilund.', status: 'planned' },
  ]},
];

const STATUS_LABEL: Record<Status, string> = {
  live: 'Live', designed: 'In design', progress: 'In progress', planned: 'Planned',
};
---

<Base title="The System" description="The tabletop rules of play for Saints of Avilund — character generation, mechanics, and Game Master tools. Currently in design.">
  <p class="eyebrow">The System</p>
  <h1>Rules of Play</h1>
  <p class="lede">
    The character system, the mechanics, and the Game Master&rsquo;s tools. The rules are being written
    section by section &mdash; this page is the map of the whole, and shows what is ready to read.
  </p>

  <div class="prose" style="margin:0 auto;">
    {parts.map((part) => (
      <section style="margin:2.2rem 0;">
        <h2 style="margin-bottom:0.6rem;">{part.part}</h2>
        <ul class="doc-list" style="margin-top:0;">
          {part.items.map((item) => (
            <li>
              <div class="doc-list__text">
                {item.href
                  ? <a class="title" href={item.href}>{item.title}</a>
                  : <span class="title" style="opacity:0.7;">{item.title}</span>}
                <span class={`sys-status sys-status--${item.status}`}>{STATUS_LABEL[item.status]}</span>
                <p class="card__blurb">{item.blurb}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <p style="margin-top:2.4rem;">
      The <a href={url('setting/')}>Setting</a> grows alongside the rules, and the
      <a href={url('scriptorium/')}>Designers&rsquo; Notes</a> track what is underway.
    </p>
  </div>

  <style>
    .sys-status {
      display: inline-block;
      margin-left: 0.6rem;
      padding: 0.05rem 0.5rem;
      border: 1px solid rgba(120, 90, 40, 0.45);
      border-radius: 999px;
      font-size: 0.68rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      vertical-align: middle;
      color: #6a532a;
      background: rgba(120, 90, 40, 0.06);
    }
    .sys-status--live { color: #2f5d3a; border-color: rgba(47, 93, 58, 0.5); background: rgba(47, 93, 58, 0.08); }
  </style>
</Base>
