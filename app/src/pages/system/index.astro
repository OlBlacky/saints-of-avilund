---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';
import { SYSTEM, STATUS_LABEL } from '../../lib/system';
---

<Base title="The System" description="The tabletop rules of play for Saints of Avilund — character generation, mechanics, and Game Master tools. Currently in design.">
  <p class="eyebrow">The System</p>
  <h1>Rules of Play</h1>
  <p class="lede">
    The character system, the mechanics, and the Game Master&rsquo;s tools. The rules are being written
    section by section &mdash; this page is the map of the whole, and shows what is ready to read.
  </p>

  <div class="prose" style="margin:0 auto;">
    {SYSTEM.map((part) => (
      <section style="margin:2.2rem 0;">
        <h2 style="margin-bottom:0.6rem;">{part.part}</h2>
        <ul class="doc-list" style="margin-top:0;">
          {part.items.map((item) => (
            <li>
              <div class="doc-list__text">
                <a class="title" href={url(`system/${item.slug}/`)}>{item.title}</a>
                <span class={`sys-status sys-status--${item.status}`}>{STATUS_LABEL[item.status]}</span>
                <p class="card__blurb">{item.blurb}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <p style="margin-top:2.4rem;">
      The <a href={url('setting/')}>Setting</a> grows alongside the rules, and the
      <a href={url('scriptorium/')}>Designers&rsquo; Notes</a> track what is underway.
    </p>
  </div>

  <style>
    .sys-status {
      display: inline-block;
      margin-left: 0.6rem;
      padding: 0.05rem 0.5rem;
      border: 1px solid rgba(120, 90, 40, 0.45);
      border-radius: 999px;
      font-size: 0.68rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      vertical-align: middle;
      color: #6a532a;
      background: rgba(120, 90, 40, 0.06);
    }
    .sys-status--live { color: #2f5d3a; border-color: rgba(47, 93, 58, 0.5); background: rgba(47, 93, 58, 0.08); }
  </style>
</Base>
