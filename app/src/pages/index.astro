---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';

const doorways = [
  {
    name: 'The Setting',
    href: url('setting/'),
    invite: 'The world of Avilund — its saints, its history, its geography, and the Library of in-world texts that record them.',
  },
  {
    name: 'The System',
    href: url('system/'),
    invite: 'The tabletop rules of play — character generation, mechanics, and Game Master tools. Currently in design.',
  },
  {
    name: 'Designers’ Notes',
    href: url('scriptorium/'),
    invite: 'Working drafts, design notes, and the artists’ reference file — for collaborators and the curious.',
  },
];
---

<Base description="A low-fantasy tabletop setting — three civilizations on one continent, read through the primary documents of the world.">
  <section class="hero">
    <figure class="hero__image">
      <img
        src={url('images/pulp/temporary-hero.png')}
        alt="A temporary placeholder hero illustration for Saints of Avilund."
      />
    </figure>
    <p class="eyebrow">Saints of Avilund — A Setting Compendium</p>
    <h1>A continent with a long memory.</h1>
    <p class="lede">
      Three civilizations have stood here. Two are forgotten.
      The third is fracturing — and writing about it.
    </p>
  </section>

  <section class="pitch">
    <div class="pitch__column">
      <h2>Three ages, one continent.</h2>
      <p>
        In Avilund the calendar reads <strong>1750</strong> in the capital, <strong>1350</strong>
        in the south, and <strong>1050</strong> in the north — all at once. Move between them and
        the world changes around you: printing presses to cathedrals to longhouses, in the
        span of a journey.
      </p>
    </div>
    <div class="pitch__column">
      <h2>Low fantasy. No spectacle.</h2>
      <p>
        Magic is real and unwelcome. A miracle is unsettling, not a set piece.
        The Faith has lost its crown but not its teeth. The Inquisitions are
        mostly over. The dragons are not coming.
      </p>
    </div>
    <div class="pitch__column">
      <h2>Read the primary sources.</h2>
      <p>
        Everything you&rsquo;ll find here was written by someone inside the world —
        and illustrated by three artists across three eras of the Empire&rsquo;s
        print history. You aren&rsquo;t reading a manual. You are reading the evidence.
      </p>
    </div>
  </section>

  <ul class="grid doorways">
    {doorways.map((d) => (
      <li>
        <a class="card" href={d.href}>
          <p class="card__name">{d.name}</p>
          <p class="card__blurb">{d.invite}</p>
        </a>
      </li>
    ))}
  </ul>
</Base>
