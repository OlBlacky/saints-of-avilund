---
import '../styles/global.scss';
import { url } from '../lib/url';
import { GLOSSARY, INLINE_TERMS } from '../lib/glossary';

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteName = 'Saints of Avilund';
const fullTitle = title ? `${title} — ${siteName}` : siteName;
const pathname = Astro.url.pathname;

// Three top-level sections + Search. Each item carries a list of URL prefixes
// to highlight against, so the existing top-level routes (/saints/, /library/,
// etc.) light up "The Setting" without needing to be moved under /setting/.
const nav = [
  { label: 'The Setting', href: url('setting/'),
    matches: ['setting/', 'saints/', 'library/', 'history/', 'geography/'] },
  { label: 'The System', href: url('system/'),
    matches: ['system/'] },
  { label: 'Designers’ Notes', href: url('scriptorium/'),
    matches: ['scriptorium/'] },
  { label: 'Search', href: url('search/'),
    matches: ['search/'] },
];

function isCurrent(item: { href: string; matches: string[] }) {
  if (item.href === url('')) return pathname === url('');
  return item.matches.some((m) => pathname.startsWith(url(m)));
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={url('favicon.svg')} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-title" href={url('')}>
          Saints of Avilund
          <span>An Imperial Compendium</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={isCurrent(item) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Saints of Avilund — a setting compendium. Drawn from the canonical record.</p>
    </footer>

    <style is:global>
      /* Hover/focus glossary for game terms (applied to bold terms on System
         pages by the decorator script below). */
      .gloss-term {
        border-bottom: 1px dotted var(--gold);
        cursor: help;
        position: relative;
      }
      .gloss-term::after {
        content: attr(data-def);
        position: absolute;
        left: 0;
        top: calc(100% + 0.4rem);
        z-index: 30;
        width: max-content;
        max-width: 19rem;
        padding: 0.5rem 0.7rem;
        background: var(--ink);
        color: var(--parchment);
        border: 1px solid var(--gold);
        border-radius: 4px;
        font-family: var(--serif);
        font-size: 0.82rem;
        font-weight: 400;
        font-style: normal;
        font-variant: normal;
        line-height: 1.45;
        letter-spacing: 0;
        text-transform: none;
        white-space: normal;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.12s ease;
        pointer-events: none;
      }
      .gloss-term:hover::after,
      .gloss-term:focus-visible::after {
        opacity: 1;
        visibility: visible;
      }
    </style>

    <script define:vars={{ glossary: GLOSSARY, inlineTerms: INLINE_TERMS }}>
      // Decorate bold game terms on System pages with a glossary tooltip.
      (function () {
        try {
          if (!location.pathname.includes('/system/')) return;
          var map = {};
          for (var k in glossary) map[k.toLowerCase()] = glossary[k];
          function lookup(text) {
            var n = (text || '').toLowerCase().trim()
              .replace(/^[+\-]?\d+\s+/, '')          // drop a leading quantity ("11 ")
              .replace(/^[("\[‘’]+/, '')
              .replace(/[.,;:!?’'")\]]+$/, '');
            if (!n) return null;
            if (map[n]) return map[n];
            if (n.slice(-1) === 's' && map[n.slice(0, -1)]) return map[n.slice(0, -1)];
            if (map[n + 's']) return map[n + 's'];
            return null;
          }
          var main = document.querySelector('main');
          if (!main) return;
          var nodes = main.querySelectorAll('strong, b');
          for (var i = 0; i < nodes.length; i++) {
            var el = nodes[i];
            if (el.getAttribute('data-def')) continue;
            var def = lookup(el.textContent);
            if (!def) continue;
            el.classList.add('gloss-term');
            el.setAttribute('data-def', def);
            el.setAttribute('tabindex', '0');
            el.setAttribute('role', 'note');
          }

          // Inline abbreviations (e.g. WRI) — wrap whole-word matches in body text.
          var inlineKeys = Object.keys(inlineTerms || {});
          if (inlineKeys.length) {
            var pattern = '\\b(' + inlineKeys.join('|') + ')\\b';
            var walker = document.createTreeWalker(main, NodeFilter.SHOW_TEXT, null);
            var hits = [];
            var tn;
            while ((tn = walker.nextNode())) {
              var pn = tn.parentNode;
              if (!pn) continue;
              var tag = pn.nodeName;
              if (tag === 'SCRIPT' || tag === 'STYLE') continue;
              if (pn.classList && pn.classList.contains('gloss-term')) continue;
              if (new RegExp(pattern).test(tn.nodeValue || '')) hits.push(tn);
            }
            hits.forEach(function (node) {
              var text = node.nodeValue;
              var frag = document.createDocumentFragment();
              var re = new RegExp(pattern, 'g');
              var last = 0, m;
              while ((m = re.exec(text))) {
                if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
                var span = document.createElement('span');
                span.className = 'gloss-term';
                span.setAttribute('data-def', inlineTerms[m[1]]);
                span.setAttribute('tabindex', '0');
                span.setAttribute('role', 'note');
                span.textContent = m[1];
                frag.appendChild(span);
                last = m.index + m[1].length;
              }
              if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
              node.parentNode.replaceChild(frag, node);
            });
          }
        } catch (e) { /* no-op */ }
      })();
    </script>
  </body>
</html>
